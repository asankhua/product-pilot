# ============================================================
# Product Pilot - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your API keys:
#   cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# LLM APIs
# ------------------------------------------------------------

# Groq API (Primary LLM - fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API (Fallback LLM - multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Vector Database (Pinecone)
# ------------------------------------------------------------

# Pinecone API Key
# Get your key at: https://app.pinecone.io/
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Pinecone index name (create in Pinecone console)
# Recommended: serverless, cosine metric, 1536 dimensions
PINECONE_INDEX=product-pilot

# Pinecone environment/region
PINECONE_ENVIRONMENT=us-east-1

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------

# PostgreSQL connection string
# For local dev: postgresql://user:password@localhost:5432/pm_windsir
# For Neon (serverless): postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/pm_windsir
DATABASE_URL=postgresql://postgres:password@localhost:5432/pm_windsir

# ------------------------------------------------------------
# External APIs (Competitive Analysis)
# ------------------------------------------------------------

# Serper API (Google Search)
# Get your key at: https://serper.dev/
SERPER_API_KEY=

# ------------------------------------------------------------
# Application Config
# ------------------------------------------------------------

# Public app URL (used in meta tags, sharing links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM defaults (override per-step in constants.ts)
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=2048
LLM_MAX_RETRIES=3

# Pipeline config
PIPELINE_STREAM_ENABLED=true
PIPELINE_RAG_TOP_K=10
PIPELINE_EMBEDDING_CHUNK_SIZE=512
PIPELINE_EMBEDDING_CHUNK_OVERLAP=50

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_PIPELINE_CONCURRENT=2
